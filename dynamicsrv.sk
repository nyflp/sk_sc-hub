import:
	java.net.URI
	java.net.http.HttpClient
	java.net.http.HttpRequest
	java.net.http.HttpRequest$BodyPublishers
	java.net.http.HttpResponse$BodyHandlers
	java.lang.Runtime
	java.io.BufferedReader
	java.io.InputStreamReader
	java.io.File

options:
	pteroFile: "plugins/Skript/scripts/sk_sc-hub/ptero.yml"
	yamlId: "ptero"

on load:
	load yaml {@pteroFile} as {@yamlId}

	set {ptero::panel} to yaml value "ptero.panel" from {@yamlId}
	set {ptero::app_key} to yaml value "ptero.app_key" from {@yamlId}
	set {ptero::client_key} to yaml value "ptero.client_key" from {@yamlId}

	set {profiles::hub::template} to yaml value "profiles.hub.template" from {@yamlId}
	set {profiles::hub::port_range} to yaml value "profiles.hub.port_range" from {@yamlId}
	set {profiles::hub::memory} to yaml value "profiles.hub.memory" from {@yamlId}
	set {profiles::hub::disk} to yaml value "profiles.hub.disk" from {@yamlId}
	set {profiles::hub::cpu} to yaml value "profiles.hub.cpu" from {@yamlId}
	set {profiles::hub::io} to yaml value "profiles.hub.io" from {@yamlId}
	set {profiles::hub::startup} to yaml value "profiles.hub.startup" from {@yamlId}
	
	set {ptero::node_id} to 1
	set {ptero::paper_egg_id} to 3
	
	set {ptero::servers::hub_dev::id} to 2
	set {ptero::servers::hub_dev::identifier} to "0c09d21d"
	set {ptero::servers::hub_dev::state} to true
	wait a second
	set {ptero::server_list::*} to getGlobal("server_list")
	{id} is "hub_dev"
	remove all "hub_dev" from {ptero::server_list::*}
	add "hub_dev" to {ptero::server_list::*}
	setGlobal("server_list", "%{ptero::server_list::*}%")

# ============================================================
# HTTP REQUEST HELPER
# ============================================================
function pteroRequest(method: text, endpoint: text, body: text, useApp: boolean) :: text:
	set {_client} to HttpClient.newHttpClient()

	if {_useApp} is true:
		set {_token} to {ptero::app_key}
	else:
		set {_token} to {ptero::client_key}

	set {_url} to "%{ptero::panel}%%{_endpoint}%"

	set {_builder} to HttpRequest.newBuilder()
	set {_builder} to {_builder}.uri(URI.create({_url}))
	set {_builder} to {_builder}.header("Authorization", "Bearer %{_token}%")
	set {_builder} to {_builder}.header("Accept", "application/vnd.pterodactyl.v1+json")
	set {_builder} to {_builder}.header("Content-Type", "application/json")

	if {_method} is "GET":
		set {_builder} to {_builder}.GET()
	else if {_method} is "POST":
		set {_builder} to {_builder}.POST(BodyPublishers.ofString({_body}))
	else if {_method} is "DELETE":
		set {_builder} to {_builder}.DELETE()
	else:
		return "0|||Method Error"

	set {_request} to {_builder}.build()
	set {_response} to {_client}.send({_request}, BodyHandlers.ofString())

	set {_javaCode} to {_response}.statusCode()
	set {_javaBody} to {_response}.body()

	set {_finalCode} to "%{_javaCode}%" parsed as number
	set {_finalBody} to "%{_javaBody}%"

	return "%{_finalCode}%|||%{_finalBody}%"

# ============================================================
# WRITE FILE (CORRIGÉ AVEC JSON BODY)
# ============================================================
function pteroWriteFile(identifier: text, fileName: text, content: text) :: text:
	set {_safeFile} to {_fileName}
	replace all " " with "%%20" in {_safeFile}
	replace all "#" with "%%23" in {_safeFile}
	replace all "&" with "%%26" in {_safeFile}
	
	set {_jsonBody} to "{""contents"":""%{_content}%""}"
	set {_endpoint} to "/api/client/servers/%{_identifier}%/files/write?file=%{_safeFile}%"
	return pteroRequest("POST", {_endpoint}, {_jsonBody}, false)

# ============================================================
# PARSE PORT RANGE
# ============================================================
function parsePortRange(r: text) :: objects:
	set {_dash} to index of "-" in {_r}
	if {_dash} is 0:
		return 0, 0

	set {_minText} to subtext of {_r} from 1 to {_dash} - 1
	set {_maxText} to subtext of {_r} from {_dash} + 1 to length of {_r}

	set {_min} to {_minText} parsed as number
	set {_max} to {_maxText} parsed as number

	return {_min}, {_max}

# ============================================================
# UTILS JSON
# ============================================================
function pteroGetAllocChunkFromBody(body: text, port: number) :: text:
	set {_posPort} to index of """port"":%{_port}%" in {_body}
	if {_posPort} is 0:
		return ""
	set {_before} to subtext of {_body} from 1 to {_posPort}
	set {_posAttr} to last index of """attributes"":{""id"":" in {_before}
	if {_posAttr} is 0:
		return ""
	set {_start} to {_posAttr}
	set {_end} to {_posAttr} + 220
	if {_end} > length of {_body}:
		set {_end} to length of {_body}
	return subtext of {_body} from {_start} to {_end}

function pteroAllocIdFromChunk(chunk: text) :: number:
	set {_tmp::*} to {_chunk} split at """id"":"
	if {_tmp::2} is not set:
		return 0
	set {_after} to {_tmp::2}
	set {_tmp2::*} to {_after} split at ","
	if {_tmp2::1} is not set:
		return 0
	return {_tmp2::1} parsed as number

function pteroAssignedFromChunk(chunk: text) :: text:
	if {_chunk} contains """assigned"":true":
		return "true"
	if {_chunk} contains """assigned"":false":
		return "false"
	return "unknown"

function pteroIsInstalling(serverId: number) :: boolean:
	set {_raw} to pteroRequest("GET", "/api/application/servers/%{_serverId}%", "{}", true)
	set {_split::*} to {_raw} split at "|||"
	set {_status} to {_split::1} parsed as number
	set {_body} to {_split::2}

	if {_status} is not 200:
		return true 
	if {_body} contains """status"":""installing""":
		return true
	return false

# ============================================================
# FIND FREE ALLOCATION
# ============================================================
function pteroFindFreeAllocation(profile: text) :: objects:
	set {_nodeId} to {ptero::node_id}
	set {_range} to {profiles::%{_profile}%::port_range}
	set {_r::*} to parsePortRange({_range})
	
	set {_rawResponse} to pteroRequest("GET", "/api/application/nodes/%{_nodeId}%/allocations?per_page=500", "{}", true)
	
	set {_split::*} to {_rawResponse} split at "|||"
	set {_status} to {_split::1} parsed as number
	set {_body} to {_split::2}

	if {_status} is not 200:
		return 0, 0

	loop ({_r::2} - {_r::1} + 1) times:
		set {_port} to {_r::1} + loop-number - 1
		set {_chunk} to pteroGetAllocChunkFromBody({_body}, {_port})
		
		if pteroAssignedFromChunk({_chunk}) is "false":
			set {_id} to pteroAllocIdFromChunk({_chunk})
			if {_id} > 0:
				return {_id}, {_port}
				
	return 0, 0

# ============================================================
# JSON EXTRACTORS
# ============================================================
function extractServerId(json: text) :: number:
	set {_parts::*} to {_json} split at """id"":"
	if {_parts::2} is set:
		set {_afterId} to {_parts::2}
		set {_numberParts::*} to {_afterId} split at ","
		if {_numberParts::1} is set:
			set {_id} to {_numberParts::1} parsed as number
			if {_id} is set:
				return {_id}
	return 0

function extractIdentifier(json: text) :: text:
	set {_parts::*} to {_json} split at """identifier"":"""
	if {_parts::2} is set:
		set {_afterIdentifier} to {_parts::2}
		set {_endParts::*} to {_afterIdentifier} split at """"
		if {_endParts::1} is set:
			set {_identifier} to {_endParts::1}
			if length of {_identifier} is 8:
				return {_identifier}
	return ""

# ============================================================
# GET SERVER UUID
# ============================================================
function getServerUUID(identifier: text) :: text:
	set {_raw} to pteroRequest("GET", "/api/client/servers/%{_identifier}%", "{}", false)
	set {_split::*} to {_raw} split at "|||"
	set {_status} to {_split::1} parsed as number
	set {_body} to {_split::2}
	
	if {_status} is 200:
		set {_parts::*} to {_body} split at """uuid"":"""
		if {_parts::2} is set:
			set {_afterUuid} to {_parts::2}
			set {_uuidParts::*} to {_afterUuid} split at """"
			if {_uuidParts::1} is set:
				return {_uuidParts::1}
	
	return ""

# ============================================================
# CREATE SERVER
# ============================================================
function pteroCreate(profile: text, serverName: text, ownerId: number, allocId: number) :: text:
	if {ptero::paper_egg_id} is not set:
		return "0|||Erreur Egg ID"
	
	set {_memory} to {profiles::%{_profile}%::memory}
	set {_disk} to {profiles::%{_profile}%::disk}
	set {_cpu} to {profiles::%{_profile}%::cpu}
	set {_io} to {profiles::%{_profile}%::io}

	set {_docker} to "ghcr.io/pterodactyl/yolks:java_21"
	set {_startup} to {profiles::%{_profile}%::startup}

	set {_json} to "{"
	set {_json} to "%{_json}%""name"":""%{_serverName}%"","
	set {_json} to "%{_json}%""user"":%{_ownerId}%,"
	set {_json} to "%{_json}%""egg"":%{ptero::paper_egg_id}%,"
	set {_json} to "%{_json}%""docker_image"":""%{_docker}%"","
	set {_json} to "%{_json}%""startup"":""%{_startup}%"","
	
	set {_json} to "%{_json}%""environment"":{"
	set {_json} to "%{_json}%""SERVER_JARFILE"":""server.jar"","
	set {_json} to "%{_json}%""MINECRAFT_VERSION"":""1.21.4"","
	set {_json} to "%{_json}%""BUILD_NUMBER"":""latest"""
	set {_json} to "%{_json}%},"
	
	set {_json} to "%{_json}%""limits"":{"
	set {_json} to "%{_json}%""memory"":%{_memory}%,""swap"":0,""disk"":%{_disk}%,""io"":%{_io}%,""cpu"":%{_cpu}%"
	set {_json} to "%{_json}%},"
	
	set {_json} to "%{_json}%""feature_limits"":{"
	set {_json} to "%{_json}%""databases"":0,""allocations"":1,""backups"":0"
	set {_json} to "%{_json}%},"
	
	set {_json} to "%{_json}%""allocation"":{"
	set {_json} to "%{_json}%""default"":%{_allocId}%"
	set {_json} to "%{_json}%}"
	
	set {_json} to "%{_json}%}"

	return pteroRequest("POST", "/api/application/servers", {_json}, true)

# ============================================================
# COPY FROM TEMPLATE
# ============================================================
function copyFromTemplate(targetIdentifier: text, profile: text) :: text:
	send "&6[COPY] Copie fichiers du template %{_profile}%..." to console
	
	set {_sourceShort} to {profiles::%{_profile}%::template}
	
	if {_sourceShort} is not set:
		send "&c[COPY] Template introuvable pour profile %{_profile}%" to console
		return "ERROR: No template for profile"
	
	set {_sourceUUID} to getServerUUID({_sourceShort})
	set {_targetUUID} to getServerUUID({_targetIdentifier})
	
	if {_sourceUUID} is "":
		send "&c[COPY] Erreur UUID template" to console
		return "ERROR: Cannot get source UUID"
	
	if {_targetUUID} is "":
		send "&c[COPY] Erreur UUID cible" to console
		return "ERROR: Cannot get target UUID"
	
	set {_jsonBody} to "{""source"":""%{_sourceUUID}%"",""target"":""%{_targetUUID}%""}"
	set {_apiUrl} to "http://192.168.1.27:8765/copy"
	
	set {_client} to HttpClient.newHttpClient()
	set {_builder} to HttpRequest.newBuilder()
	set {_builder} to {_builder}.uri(URI.create({_apiUrl}))
	set {_builder} to {_builder}.header("Content-Type", "application/json")
	set {_builder} to {_builder}.POST(BodyPublishers.ofString({_jsonBody}))
	
	set {_request} to {_builder}.build()
	set {_response} to {_client}.send({_request}, BodyHandlers.ofString())
	
	set {_statusCode} to {_response}.statusCode()
	set {_responseBody} to {_response}.body()
	
	if {_statusCode} is 200:
		if {_responseBody} contains """exit_code"": 0":
			send "&a✅ Copie OK !" to console
			return "SUCCESS"
	
	send "&c❌ Erreur copie: %{_statusCode}%" to console
	return "ERROR: API %{_statusCode}%"


# ============================================================
# POWER & DELETE
# ============================================================
function pteroPower(identifier: text, signal: text) :: text:
	set {_json} to "{""signal"": ""%{_signal}%""}"
	return pteroRequest("POST", "/api/client/servers/%{_identifier}%/power", {_json}, false)

function pteroDelete(serverId: number) :: text:
	return pteroRequest("DELETE", "/api/application/servers/%{_serverId}%?force=true", "{}", true)

# ============================================================
# MASTER FUNCTION (SANS RETURN APRÈS WAIT)
# ============================================================
function dynSysCall(action: text, arg: text):
	set {_act} to {_action} in lower case
	
	if {_act} is "create":
		set {_profile} to {_arg}
		set {_ownerId} to 1
		
		send "&6[SYS] Recherche allocation %{_profile}%..." to console
		set {_allocData::*} to pteroFindFreeAllocation({_profile})
		set {_allocId} to {_allocData::1}
		set {_port} to {_allocData::2}
		
		if {_allocId} = 0:
			send "&cERROR: Pas d'allocation libre" to console
			stop
			
		set {_range::*} to parsePortRange({profiles::%{_profile}%::port_range})
		set {_index} to ({_port} - {_range::1}) + 1
		set {_serverName} to "%{_profile}%_%{_index}%"
		if {_index} < 10:
			set {_serverName} to "%{_profile}%_0%{_index}%"
			
		send "&6[SYS] Création %{_serverName}%..." to console
		set {_raw} to pteroCreate({_profile}, {_serverName}, {_ownerId}, {_allocId})
		set {_split::*} to {_raw} split at "|||"
		set {_status} to {_split::1} parsed as number
		set {_body} to {_split::2}
		
		if {_status} is not between 200 and 299:
			send "&cERROR API Create: %{_status}%" to console
			stop

		set {_sid} to extractServerId({_body})
		set {_identifier} to extractIdentifier({_body})
		set {ptero::servers::%{_serverName}%::id} to {_sid}
		set {ptero::servers::%{_serverName}%::identifier} to {_identifier}
		add {_serverName} to {ptero::server_list::*}
		setGlobal("server_list", "%{ptero::server_list::*}%")
		
		send "&6[SYS] Installation..." to console
		set {_attempts} to 0
		
		loop 100 times:
			if pteroIsInstalling({_sid}) is false:
				send "&a[SYS] Serveur installé !" to console
				exit loop
			wait 0.5 seconds
		
		wait 1 second
		set {_copyRes} to copyFromTemplate({_identifier}, {_profile})
		
		if {_copyRes} contains "SUCCESS":
			send "&a[WRITE] Création server_id.txt..." to console
			set {_writeRes} to pteroWriteFile({_identifier}, "server_id.txt", {_serverName})
			set {_wSplit::*} to {_writeRes} split at "|||"
			set {_wCode} to {_wSplit::1} parsed as number
			
			if {_wCode} is between 200 and 299:
				send "&a✅ Fichier ID créé !" to console
			else:
				send "&c❌ Erreur write: %{_wCode}%" to console
			
			dynSysCall("start", {_serverName})
			send "&aSUCCESS: %{_serverName}% créé" to console
		else:
			send "&cWARNING: Copie échouée" to console

	else if {_act} is "start" or "stop" or "restart" or "kill":
		set {_serverName} to {_arg}
		set {_identifier} to {ptero::servers::%{_serverName}%::identifier}
		
		if {_identifier} is not set:
			send "&cERROR: Serveur '%{_serverName}%' inconnu" to console
			stop
			
		set {_raw} to pteroPower({_identifier}, {_act})
		set {_split::*} to {_raw} split at "|||"
		
		if {_split::1} contains "204":
			if {_act} is "start" or "restart":
				set {ptero::servers::%{_serverName}%::state} to true
			else if {_act} is "kill" or "stop":
				clear {ptero::servers::%{_serverName}%::state}
		
		if {_split::1} contains "200" or "204":
			send "&aSUCCESS: %{_act}% %{_serverName}%" to console
		else:
			send "&cERROR API: %{_split::1}%" to console

	else if {_act} is "delete":
		set {_serverName} to {_arg}
		
		if {_serverName} is "hub_dev":
			send "&cERROR: hub_dev protégé" to console
			stop
		
		set {_sid} to {ptero::servers::%{_serverName}%::id}
		
		if {_sid} is not set:
			send "&cERROR: ID introuvable" to console
			stop
			
		set {_raw} to pteroDelete({_sid})
		set {_split::*} to {_raw} split at "|||"
		
		if {_split::1} contains "204" or "200":
			delete {ptero::servers::%{_serverName}%::*}
			remove {_serverName} from {ptero::server_list::*}
			setGlobal("server_list", "%{ptero::server_list::*}%")
			send "&aSUCCESS: %{_serverName}% supprimé" to console
		else:
			send "&cERROR API: %{_split::1}%" to console

command /dynsys [<text>] [<text>]:
	permission: skperm.admin
	trigger:
		if arg-1 is not set:
			send "&cSyntaxe:%nl%/dynsys create <hub>%nl%/dynsys <start|stop|restart|kill|delete> <nom>"
			stop
		if arg-2 is not set:
			send "&cManque argument 2"
			stop
		
		dynSysCall(arg-1, arg-2)
